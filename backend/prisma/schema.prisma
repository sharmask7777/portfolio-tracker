generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  password        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  ownedFamilies   FamilyGroup[]
  familyMemberOf  FamilyMember[]
  managedProfiles ManagedProfile[]
  portfolios      Portfolio[]

  @@index([email])
}

model ManagedProfile {
  id         String      @id @default(uuid())
  name       String
  pan        String
  userId     String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  taxSlab    Float       @default(0.3)
  user       User        @relation(fields: [userId], references: [id])
  portfolios Portfolio[]

  @@unique([userId, pan])
  @@index([userId])
}

model FamilyGroup {
  id        String         @id @default(uuid())
  name      String
  ownerId   String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  owner     User           @relation(fields: [ownerId], references: [id])
  members   FamilyMember[]

  @@index([ownerId])
}

model FamilyMember {
  id        String      @id @default(uuid())
  userId    String
  groupId   String
  role      String      @default("MEMBER")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  group     FamilyGroup @relation(fields: [groupId], references: [id])
  user      User        @relation(fields: [userId], references: [id])

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
}

model Portfolio {
  id               String             @id @default(uuid())
  name             String
  userId           String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  managedProfileId String?
  folios           Folio[]
  goals            Goal[]
  managedProfile   ManagedProfile?    @relation(fields: [managedProfileId], references: [id])
  user             User               @relation(fields: [userId], references: [id])
  history          PortfolioHistory[]

  @@index([userId])
}

model PortfolioHistory {
  id             String    @id @default(uuid())
  portfolioId    String
  date           DateTime
  value          Float
  investedAmount Float
  createdAt      DateTime  @default(now())
  portfolio      Portfolio @relation(fields: [portfolioId], references: [id])

  @@unique([portfolioId, date])
  @@index([portfolioId])
  @@index([date])
}

model HistoricalNAV {
  id        String   @id @default(uuid())
  amfiCode  String
  date      DateTime
  nav       Float
  createdAt DateTime @default(now())

  @@unique([amfiCode, date])
  @@index([amfiCode])
  @@index([date])
}

model Goal {
  id           String    @id @default(uuid())
  name         String
  targetAmount Float
  targetDate   DateTime
  portfolioId  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  portfolio    Portfolio @relation(fields: [portfolioId], references: [id])
  assets       Asset[]   @relation("GoalAssets")

  @@index([portfolioId])
}

model Asset {
  id               String    @id @default(uuid())
  type             AssetType
  name             String
  isin             String?   @unique
  amfiCode         String?   @unique
  symbol           String?   @unique
  exitLoadMetadata String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  folios           Folio[]
  goals            Goal[]    @relation("GoalAssets")

  @@index([isin])
  @@index([amfiCode])
}

model Folio {
  id           String        @id @default(uuid())
  number       String
  amc          String?
  pan          String?
  portfolioId  String
  assetId      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  asset        Asset         @relation(fields: [assetId], references: [id])
  portfolio    Portfolio     @relation(fields: [portfolioId], references: [id])
  transactions Transaction[]

  @@unique([number, assetId, portfolioId])
  @@index([portfolioId])
  @@index([assetId])
}

model Transaction {
  id         String   @id @default(uuid())
  date       DateTime
  type       String
  amount     Float
  units      Float
  nav        Float
  balance    Float
  folioId    String
  externalId String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  folio      Folio    @relation(fields: [folioId], references: [id])

  @@index([folioId])
  @@index([date])
}

model UploadJob {
  id          String          @id @default(uuid())
  userId      String
  filePath    String
  status      UploadJobStatus @default(PENDING)
  message     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  startedAt   DateTime?
  completedAt DateTime?

  @@index([userId])
  @@index([status])
}

enum AssetType {
  MUTUAL_FUND
  STOCK
  FIXED_DEPOSIT
  EPF
  PPF
  SGB
  PHYSICAL_GOLD
}

enum UploadJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
