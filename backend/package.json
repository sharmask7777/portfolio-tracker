{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run worker\"",
    "dev:server": "ts-node-dev --respawn --transpile-only --ignore-watch uploads src/index.ts",
    "worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "build": "rimraf dist && tsc",
    "lint": "eslint .",
    "test": "jest",
    "test:docker": "docker build -t portfolio-test-img . && docker run --rm portfolio-test-img ls /app/prisma.config.js && docker run --rm -e DATABASE_URL='postgresql://fake:fake@localhost/fake' portfolio-test-img npx prisma validate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.0.0",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-irr": "^2.0.5",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.8.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.4.0",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
