#!/usr/bin/env bash
. "$(dirname -- "$0")/_/husky.sh"

set -e

echo "⏳ Running Docker sanity checks..."
npm run test:docker --prefix backend

echo "🐳 Starting Docker compose stack for E2E tests..."
npm run docker:up

# Ensure we always tear down the stack, even if the tests fail
cleanup() {
  echo "🧹 Tearing down Docker stack..."
  npm run docker:down
}
trap cleanup EXIT

echo "⏳ Waiting for services to become ready (10s)..."
sleep 10

echo "⏳ Running Playwright E2E tests against Docker stack..."
npm run test:e2e:docker --prefix frontend
