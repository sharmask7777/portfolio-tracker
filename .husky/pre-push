#!/usr/bin/env bash
. "$(dirname -- "$0")/_/husky.sh"

set -e

echo "Running backend Docker smoke test..."
cd backend && npm run test:docker
cd ..

echo "Running frontend Docker smoke test..."
cd frontend && npm run test:docker
cd ..

echo "🐳 Starting Docker compose stack for E2E tests..."
export NODE_ENV=development
npm run docker:up

# Ensure we always tear down the stack, even if the tests fail
cleanup() {
  echo "🧹 Tearing down Docker stack..."
  npm run docker:down
}
trap cleanup EXIT

echo "⏳ Waiting for services to become ready (10s)..."
sleep 10

echo "⏳ Running Playwright E2E tests against Docker stack..."
npm run test:e2e:docker --prefix frontend
